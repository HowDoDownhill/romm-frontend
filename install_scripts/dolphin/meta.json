{
  "name": "Dolphin",
  "executable_name": {
    "windows": "Dolphin.exe",
    "linux": "Dolphin_Emulator-2603a-anylinux-x86_64.AppImage",
    "macos": "Dolphin"
  },
  "emulator_dir_name": {
    "windows": "dolphin",
    "linux": "dolphin",
    "macos": "dolphin"
  },
  "install_recipe": {
    "windows": {
      "type": "direct_url",
      "url": "https://dl.dolphin-emu.org/releases/2606/dolphin-2606-x64.7z",
      "extract": true,
      "extract_folder_regex": "dolphin-*"
    },
    "linux": {
      "type": "github_release",
      "repo": "pkgforge-dev/Dolphin-emu-AppImage",
      "asset_regex": "Dolphin_Emulator-2603a-anylinux-x86_64.AppImage",
      "extract": false
    }
  },
  "launch_args_with_game": "-b -u ./ -e \"{rom_path}\"",
  "launch_args_without_game": "-u ./",
  "settings_fields": [
    {
      "id": "fullscreen",
      "label": "Start in Fullscreen",
      "type": "boolean",
      "default_value_bool": true,
      "launch_arg_true": "-C Dolphin.Display.Fullscreen=True",
      "launch_arg_false": "-C Dolphin.Display.Fullscreen=False"
    },
    {
      "id": "video_backend",
      "label": "Video Backend",
      "type": "dropdown",
      "default_value_string": "Vulkan",
      "options": {
        "Vulkan": "Vulkan",
        "Direct3D 11": "D3D",
        "Direct3D 12": "D3D12",
        "OpenGL": "OGL"
      },
      "launch_arg_format": "-C Dolphin.Display.GFXBackend={value}"
    }
  ],
  "relative_save_path": {
    "ngc": [
      "User/GC/EUR/Card A",
      "User/GC/JAP/Card A",
      "User/GC/USA/Card A"
    ]
  }
}
