{
  "name": "pcsx2",
  "executable_name": {
    "windows": "pcsx2-qt.exe",
    "linux": "pcsx2.AppImage",
    "macos": "pcsx2"
  },
  "emulator_dir_name": {
    "windows": "pcsx2",
    "linux": "pcsx2",
    "macos": "pcsx2"
  },
  "emulator_bios_path": {
    "windows": "bios",
    "linux": "bios",
    "macos": "bios"
  },
  "launch_args_with_game": "-batch -fullscreen -portable -bigpicture -- \"{rom_path}\"",
  "launch_args_without_game": "-portable",
  "install_recipe": {
    "windows": {
      "type": "github_release",
      "repo": "PCSX2/pcsx2",
      "asset_regex": ".*windows-x64-Qt\\.7z$",
      "extract": true
    },
    "linux": {
      "type": "github_release",
      "repo": "PCSX2/pcsx2",
      "asset_regex": ".*linux-AppImage-64bit-Qt\\.AppImage$",
      "extract": false
    }
  }
}