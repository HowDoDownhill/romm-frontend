{
  "name": "pcsx2",
  "executable_name": {
    "windows": "pcsx2-qt.exe",
    "linux": "pcsx2.AppImage",
    "macos": "pcsx2"
  },
  "emulator_dir_name": {
    "windows": "pcsx2",
    "linux": "pcsx2",
    "macos": "pcsx2"
  },
  "emulator_bios_path": {
    "windows": "bios",
    "linux": "bios",
    "macos": "bios"
  },
  "relative_save_path": {
    "ps2": "memcards"
  },
  "launch_args_with_game": "-batch -fullscreen -portable -bigpicture -- \"{rom_path}\"",
  "launch_args_without_game": "-portable",
  "install_recipe": {
    "windows": {
      "type": "github_release",
      "repo": "PCSX2/pcsx2",
      "asset_regex": ".*windows-x64-Qt\\.7z$",
      "extract": true
    },
    "linux": {
      "type": "github_release",
      "repo": "PCSX2/pcsx2",
      "asset_regex": ".*linux-AppImage-64bit-Qt\\.AppImage$",
      "extract": false
    }
  },
  "settings_fields": [
    {
      "id": "internal_resolution",
      "label": "Internal Resolution",
      "type": "dropdown",
      "default_value_string": "1",
      "config_file_relative_path": "inis/PCSX2.ini",
      "config_section": "EmuCore/GS",
      "config_key": "upscale_multiplier",
      "options": {
        "Native (1x)": "1",
        "720p (2x)": "2",
        "1080p (3x)": "3",
        "1440p (4x)": "4",
        "2160p (6x)": "6",
        "2880p (8x)": "8"
      }
    },
    {
      "id": "aspect_ratio",
      "label": "Aspect Ratio",
      "type": "dropdown",
      "default_value_string": "Auto 4:3/3:2",
      "config_file_relative_path": "inis/PCSX2.ini",
      "config_section": "EmuCore/GS",
      "config_key": "AspectRatio",
      "options": {
        "Auto 4:3/3:2": "Auto 4:3/3:2",
        "Standard (4:3)": "4:3",
        "Widescreen (16:9)": "16:9",
        "Stretch": "Stretch"
      }
    },
    {
      "id": "per_game_memcard",
      "label": "Per-Game Memory Card",
      "type": "hidden",
      "default_value_string": "RomM_{game_id}.ps2",
      "config_file_relative_path": "inis/PCSX2.ini",
      "config_section": "MemoryCards",
      "config_key": "Slot1_Filename"
    },
    {
      "id": "vsync",
      "label": "VSync",
      "type": "dropdown",
      "default_value_string": "0",
      "config_file_relative_path": "inis/PCSX2.ini",
      "config_section": "EmuCore/GS",
      "config_key": "VsyncEnable",
      "options": {
        "Off": "0",
        "Standard": "1"
      }
    }
  ]
}