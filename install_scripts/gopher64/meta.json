{
  "name": "gopher64",
  "executable_name": {
    "windows": "gopher64.exe",
    "linux": "gopher64",
    "macos": "gopher64"
  },
  "emulator_dir_name": {
    "windows": "gopher64",
    "linux": "gopher64",
    "macos": "gopher64"
  },
  "launch_args_with_game": "\"{rom_path}\"",
  "launch_args_without_game": "",
  "install_recipe": {
    "windows": {
      "type": "github_release",
      "repo": "gopher64/gopher64",
      "asset_regex": ".*windows-x86_64\\.exe$",
      "extract": false
    },
    "linux": {
      "type": "github_release",
      "repo": "gopher64/gopher64",
      "asset_regex": ".*linux-x86_64$",
      "extract": false
    }
  },
  "relative_save_path": {
    "n64": "portable_data/data/saves/"
  },
  "settings_fields": [
    {
      "id": "upscale",
      "label": "Upscale",
      "type": "dropdown",
      "config_file_relative_path": "portable_data/config/config.json",
      "config_section": "video",
      "config_key": "upscale",
      "default_value_string": "1",
      "options": {
        "1x": "1",
        "2x": "2",
        "3x": "3",
        "4x": "4",
        "5x": "5",
        "6x": "6",
        "7x": "7",
        "8x": "8"
      }
    },
    {
      "id": "ssaa",
      "label": "SSAA",
      "type": "boolean",
      "config_file_relative_path": "portable_data/config/config.json",
      "config_section": "video",
      "config_key": "ssaa",
      "default_value_bool": false
    },
    {
      "id": "integer_scaling",
      "label": "Integer Scaling",
      "type": "boolean",
      "config_file_relative_path": "portable_data/config/config.json",
      "config_section": "video",
      "config_key": "integer_scaling",
      "default_value_bool": false
    },
    {
      "id": "fullscreen",
