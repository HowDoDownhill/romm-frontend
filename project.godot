config_version=5

[application]

config/name="romm-frontend"
run/main_scene="uid://c181xd67fwosi"
config/features=PackedStringArray("4.6", "C#", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

AppInstance="*uid://cukewmk3ypiu7"
ConfigManager="*uid://lsoicc5h860p"
RomMAPI="*uid://c45fdarm7kidr"
CacheManager="*uid://0rycpw7unjjb"
DataBus="*uid://c3ihjck7ojmb6"
DownloadManager="*uid://cahae8cxkj01b"
EmulatorManager="*uid://mc0jjiebfh7k"
